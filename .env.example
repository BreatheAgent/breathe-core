# Breathe Core — Environment Configuration
# Copy to .env and fill in your values

# ══════════════════════════════════════════════════════
# Chain RPCs
# ══════════════════════════════════════════════════════
BASE_RPC_URL="https://mainnet.base.org"
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
POLYGON_RPC_URL="https://polygon-rpc.com"

# ══════════════════════════════════════════════════════
# Wallet Keys (NEVER commit these!)
# ══════════════════════════════════════════════════════
TREASURY_PRIVATE_KEY="your_evm_private_key_here"
SOLANA_PRIVATE_KEY="your_solana_private_key_here"

# ══════════════════════════════════════════════════════
# API Keys
# ══════════════════════════════════════════════════════
VIRTUALS_API_KEY="your_virtuals_api_key"
OPENAI_API_KEY="your_openai_api_key"
POLYMARKET_API_KEY="your_polymarket_api_key"
DEXSCREENER_API_KEY="your_dexscreener_api_key"

# ══════════════════════════════════════════════════════
# Risk Parameters
# ══════════════════════════════════════════════════════
RISK_TOLERANCE="moderate"          # conservative, moderate, aggressive
DAILY_SPEND_LIMIT="100"            # Max USDC per day without approval
MAX_LEVERAGE="3.0"                 # Max leverage for perps
MAX_SINGLE_TRADE_PCT="0.10"       # Max 10% of treasury per trade
MAX_MEME_TRADE_PCT="0.02"         # Max 2% of treasury per meme trade
STOP_LOSS_PCT="0.30"              # 30% stop-loss
TAKE_PROFIT_MEME="3.0"            # 3x take-profit for memes

# ══════════════════════════════════════════════════════
# Allocation (must sum to 1.0)
# ══════════════════════════════════════════════════════
ALLOC_DEFI="0.40"
ALLOC_PERPS="0.25"
ALLOC_POLYMARKET="0.20"
ALLOC_MEMES="0.15"

# ══════════════════════════════════════════════════════
# Operational
# ══════════════════════════════════════════════════════
SCAN_INTERVAL="60"                 # Seconds between growth cycles
REBALANCE_INTERVAL="3600"          # Seconds between rebalance checks
DRY_RUN="true"                     # Set to false for real transactions
LOG_LEVEL="INFO"
